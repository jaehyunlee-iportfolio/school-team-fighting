# Firebase Console → 프로젝트 설정 → 일반 → 내 앱 → SDK snippet
# 이 두 값만 있으면 Auth / Firestore 모두 동작합니다.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# 운영회의록 본문 다듬기 / 이력서 「지원 동기 및 포부」 작성 — Anthropic Claude API
# 미설정 시 AI 호출이 500 에러 반환.
ANTHROPIC_API_KEY=
# CLAUDE_MEETING_MODEL=claude-sonnet-4-5-20250929
# CLAUDE_RESUME_MODEL=claude-sonnet-4-6

# 이력서 첨부 자료(hwp/hwpx/docx/pptx/xlsx) 텍스트 추출 — Polaris DataInsight API
# 미설정 시 자료 업로드 행은 빈 컨텍스트로 AI 생성.
POLARIS_DATAINSIGHT_API_KEY=
